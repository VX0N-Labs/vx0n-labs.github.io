[
{{- $comma := false -}}
{{- range .Site.RegularPages -}}
{{- if or .Params.hidden (eq .Section "team") (eq .RelPermalink "/vxon/") }}{{ continue }}{{ end -}}
{{- if $comma }},{{ end }}
{
    "title": {{ .Title | jsonify }},
    "description": {{ .Params.description | jsonify }},
    "author": {{ .Params.author | jsonify }},
    "url": {{ .RelPermalink | jsonify }},
    "tags": {{ .Params.tags | jsonify }},
    "redirect": {{ .Params.redirect | jsonify }},
    "reading_time": {{ .ReadingTime }}
}
{{- $comma = true -}}
{{- end }}
]